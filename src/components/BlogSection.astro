---
/**
 * BlogSection - displays the "Latest writing" section with recent blog posts.
 *
 * @param posts - Array of blog posts to display
 * @param hideWhen - Minimum number of posts required to show section (default: 2)
 */
import type { BlogPost } from "../lib/rss-client";
import { formatExcerpt, formatDate } from "../lib/utils";

interface Props {
  posts: BlogPost[];
  hideWhen?: number;
}

const { posts, hideWhen = 2 } = Astro.props;

// Hide section if fewer than hideWhen posts available
const shouldShow = posts.length >= hideWhen;
---

{shouldShow && (
  <section
    class="px-6 pb-24 md:px-12 lg:px-24 max-w-5xl mx-auto w-full"
    aria-labelledby="latest-writing-heading"
  >
    <div class="border-t border-hairline">
      <div class="py-6 md:py-8 border-b border-hairline flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="font-mono text-xs tracking-widest text-muted uppercase mb-3">
            Latest writing
          </p>
          <h2 id="latest-writing-heading" class="font-display text-3xl md:text-4xl font-semibold tracking-tight">
            Recent posts from my blog.
          </h2>
        </div>
      </div>

      <div>
        {posts.map((post) => (
          <article class="py-6 md:py-8 border-b border-hairline grid gap-4 md:grid-cols-[minmax(0,1fr)_auto] md:items-start">
            <div>
              <a
                href={post.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group block"
              >
                <h3 class="font-display text-2xl md:text-3xl font-semibold tracking-tight group-hover:text-teal transition-colors">
                  {post.title}
                </h3>
              </a>
              <p class="mt-2 font-mono text-xs tracking-widest text-muted uppercase">
                {formatDate(post.pubDate)}
              </p>
              <p class="mt-3 text-muted leading-relaxed max-w-2xl">
                {formatExcerpt(post.description, 150)}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
)}
