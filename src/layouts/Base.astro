---
import "../styles/global.css";
import { buildHeadMetadata } from "../lib/metadata";
import type { PageMeta } from "../lib/metadata";

interface Props {
  meta: PageMeta;
}

const { meta } = Astro.props;
const head = buildHeadMetadata(meta);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{meta.title}</title>
    <link rel="canonical" href={head.canonical} />
    <link rel="icon" type="image/svg+xml" href={head.favicons.svg} />
    <link rel="shortcut icon" href={head.favicons.shortcut} />
    <link rel="apple-touch-icon" href={head.favicons.appleTouchIcon} />
    {meta.description && <meta name="description" content={meta.description} />}

    <!-- Open Graph -->
    <meta property="og:title" content={head.og.title} />
    <meta property="og:url" content={head.og.url} />
    <meta property="og:type" content={head.og.type} />
    {head.og.description && <meta property="og:description" content={head.og.description} />}
    <meta property="og:image" content={head.og.image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Yushi Cui, Full-Stack Product Engineer" />

    <!-- Twitter -->
    <meta name="twitter:card" content={head.twitter.card} />
    <meta name="twitter:title" content={head.twitter.title} />
    {head.twitter.description && <meta name="twitter:description" content={head.twitter.description} />}
    <meta name="twitter:image" content={head.twitter.image} />

    <!-- JSON-LD -->
    {head.jsonLd && <script is:inline type="application/ld+json" set:html={head.jsonLd} />}
    {head.additionalJsonLd.map((jsonLd) => (
      <script is:inline type="application/ld+json" set:html={jsonLd} />
    ))}

    {meta.slug === "/" && (
      <>
        <link
          rel="preload"
          as="image"
          href="/profile-light-320.webp"
          imagesrcset="/profile-light-320.webp 320w, /profile-light-480.webp 480w, /profile-light-720.webp 720w"
          imagesizes="(min-width: 1024px) 18rem, (min-width: 768px) 16rem, (min-width: 640px) 14rem, 12rem"
          fetchpriority="high"
          media="(prefers-color-scheme: light)"
        />
        <link
          rel="preload"
          as="image"
          href="/profile-dark-320.webp"
          imagesrcset="/profile-dark-320.webp 320w, /profile-dark-480.webp 480w, /profile-dark-720.webp 720w"
          imagesizes="(min-width: 1024px) 18rem, (min-width: 768px) 16rem, (min-width: 640px) 14rem, 12rem"
          fetchpriority="high"
          media="(prefers-color-scheme: dark)"
        />
      </>
    )}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-canvas text-ink font-body antialiased">
    <div class="scroll-progress" aria-hidden="true"></div>

    <!-- Masthead: name + wayfinding + theme toggle, one line, sticky -->
    <header class="site-masthead sticky top-0 z-40 border-b border-hairline">
      <div class="max-w-6xl mx-auto px-4 sm:px-5 md:px-12 lg:px-20 h-16 flex items-center justify-between gap-4 sm:gap-6">
        <a href="/" class="font-display text-base font-bold tracking-tight hover:text-cobalt transition-colors">
          Yushi Cui
        </a>
        <nav class="flex items-center gap-4 sm:gap-5 md:gap-8 font-mono text-[0.625rem] sm:text-[0.6875rem] md:text-xs tracking-[0.18em] uppercase">
          <a href="/#projects" class="text-muted hover:text-ink transition-colors">Work</a>
          <a href="/#writing" class="hidden sm:inline text-muted hover:text-ink transition-colors">Writing</a>
          <a href="/#contact" class="text-muted hover:text-ink transition-colors">Contact</a>
          <button
            id="theme-toggle"
            class="theme-toggle -mr-1 w-8 h-8 rounded-full flex items-center justify-center text-muted hover:text-ink transition-colors shrink-0"
            aria-label="Toggle theme"
          >
            <svg class="sun-icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg class="moon-icon hidden" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <slot />

    <!-- Theme toggle script - runs before paint to prevent flash -->
    <script is:inline>
      (function() {
        const THEME_KEY = 'theme';

        // Get saved theme or system preference
        function getTheme() {
          const saved = localStorage.getItem(THEME_KEY);
          if (saved === 'light' || saved === 'dark') return saved;
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }

        // Apply theme to document
        function applyTheme(theme) {
          const html = document.documentElement;
          if (theme === 'dark') {
            html.classList.add('dark');
            html.classList.remove('light');
          } else {
            html.classList.remove('dark');
            html.classList.add('light');
          }
        }

        // Initialize theme immediately
        applyTheme(getTheme());

        // Set up toggle after DOM is ready
        document.addEventListener('DOMContentLoaded', function() {
          const toggle = document.getElementById('theme-toggle');
          if (!toggle) return;

          toggle.addEventListener('click', function() {
            const current = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
            const next = current === 'dark' ? 'light' : 'dark';
            localStorage.setItem(THEME_KEY, next);
            applyTheme(next);
          });
        });

        // Listen for system preference changes (only if no manual override)
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
          if (!localStorage.getItem(THEME_KEY)) {
            applyTheme(e.matches ? 'dark' : 'light');
          }
        });
      })();
    </script>
  </body>
</html>
