---
import Base from "../layouts/Base.astro";

const description = "Privacy notes for yushi91.com, the personal portfolio of Yushi Cui.";
---

<Base
  meta={{
    slug: "/privacy/",
    title: "Privacy - Yushi Cui",
    description,
  }}
>
  <main class="px-5 md:px-12 lg:px-20 py-16 md:py-24 max-w-5xl mx-auto w-full">
    <a href="/" class="font-mono text-xs tracking-widest uppercase text-muted hover:text-cobalt transition-colors">
      ← Home
    </a>

    <h1 class="mt-10 font-display text-[clamp(2.75rem,7vw,5rem)] font-bold leading-[1.02] tracking-[-0.025em]">
      Privacy
    </h1>

    <div class="mt-8 space-y-8 text-muted leading-relaxed max-w-3xl">
      <section>
        <h2 class="font-display text-2xl font-semibold tracking-tight text-ink">What this site collects</h2>
        <p class="mt-3">
          This is a static portfolio site. It does not run its own user accounts, analytics database, or tracking system.
        </p>
      </section>

      <section>
        <h2 class="font-display text-2xl font-semibold tracking-tight text-ink">Contact form</h2>
        <p class="mt-3">
          If you use the contact form, your submitted name, email, and message are sent through Web3Forms so I can reply. You can also email me directly instead.
        </p>
      </section>

      <section>
        <h2 class="font-display text-2xl font-semibold tracking-tight text-ink">External links</h2>
        <p class="mt-3">
          Links to GitHub, LinkedIn, the blog, and project websites are governed by those services' own privacy practices.
        </p>
      </section>
    </div>
  </main>
</Base>
