---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { formatExperienceDate, formatExperienceTitle, getCurrentRole } from "../lib/experience";
import { primaryLink } from "../lib/project";
import { getLatestPosts, type BlogPost } from "../lib/rss-client";
import { formatExcerpt, formatDate } from "../lib/utils";

const projects = (await getCollection("projects")).sort(
  (left, right) => left.data.ordering - right.data.ordering,
);

const experience = (await getCollection("experience")).sort(
  (left, right) => left.data.ordering - right.data.ordering,
);

// Current role drives the status band beneath the hero.
const current = getCurrentRole(experience.map(e => e.data));

// Asymmetric rhythm: flagship leads full-width, the rest fall into an uneven
// grid. Indexed by position so the grid never collapses to equal thirds.
const cardSpans = ["lg:col-span-12", "lg:col-span-7", "lg:col-span-5", "lg:col-span-12"];

// Fetch latest blog posts at build time
const latestPosts = await getLatestPosts(3);
const hasEnoughPosts = latestPosts.length >= 2;
---

<Base
  meta={{
    slug: "/",
    title: "Yushi Cui - Full-Stack Product Engineer",
    description:
      "Full-Stack Product Engineer based in Auckland, NZ. I build products end to end, from idea to shipped.",
  }}
>
  <main>
    <!-- Hero: editorial, type-forward, four elements only -->
    <section class="relative min-h-[calc(100dvh-4rem)] flex items-center">
      <div class="w-full max-w-6xl mx-auto px-5 md:px-12 lg:px-20 py-16 md:py-20">
        <div class="max-w-4xl">
          <p data-rise class="font-mono text-xs md:text-sm tracking-[0.22em] text-teal uppercase">
            Full-Stack Product Engineer
          </p>

          <h1 data-rise="2" class="mt-6 font-display text-[clamp(2.75rem,6vw,5.25rem)] font-extrabold leading-[1.0] tracking-[-0.02em] text-balance">
            I build products <span class="text-teal">end to end</span>, from idea to shipped.
          </h1>

          <p data-rise="3" class="mt-7 text-lg md:text-xl text-muted max-w-2xl leading-relaxed">
            I turn vague ideas into working products fast, then harden the best into production. Full-stack TypeScript, AI where it earns its place.
          </p>

          <div data-rise="4" class="mt-10 flex flex-wrap gap-3">
            <a
              href="mailto:realYushi@gmail.com"
              class="magnetic-cta inline-flex items-center bg-ink text-canvas px-6 py-3 font-display font-semibold text-sm tracking-wide rounded-[var(--radius-control)] transition-colors duration-200 hover:bg-teal active:scale-[0.98]"
            >
              Get in touch
            </a>
            <a
              href="#projects"
              class="inline-flex items-center border border-hairline text-ink px-6 py-3 font-display font-semibold text-sm tracking-wide rounded-[var(--radius-control)] transition-all duration-200 hover:border-teal hover:text-teal active:scale-[0.98]"
            >
              See work
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Status band: real, current credential facts + outbound authority -->
    <section class="border-y border-hairline" aria-label="At a glance">
      <div class="max-w-6xl mx-auto px-5 md:px-12 lg:px-20 py-5 grid gap-4 md:grid-cols-[1fr_1fr_auto] md:items-center font-mono text-xs tracking-[0.12em] uppercase">
        {current && current.kind === "role" && (
          <p class="flex items-baseline gap-2">
            <span class="text-muted">Currently</span>
            <span class="text-ink truncate">{current.org}</span>
          </p>
        )}
        <p class="flex items-baseline gap-2">
          <span class="text-muted">Based in</span>
          <span class="text-ink">Auckland, New Zealand</span>
        </p>
        <nav class="flex gap-5 md:gap-7 md:justify-end" aria-label="Profiles">
          <a href="https://github.com/realYushi" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-teal transition-colors">GitHub</a>
          <a href="https://www.linkedin.com/in/yushi-cui/" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-teal transition-colors">LinkedIn</a>
          <a href="https://blog.yushi91.com" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-teal transition-colors">Blog</a>
        </nav>
      </div>
    </section>

    <!-- Approach: single editorial statement, no eyebrow -->
    <section class="px-5 md:px-12 lg:px-20 py-20 md:py-28 max-w-6xl mx-auto w-full">
      <div data-reveal class="max-w-4xl">
        <h2 class="font-display text-2xl md:text-4xl font-semibold tracking-tight leading-[1.2] text-balance">
          I ship fast, then iterate. AI tools speed up the <span class="text-teal">0 to 1</span>, but judgment decides what survives.
        </h2>
        <p class="mt-6 text-muted leading-relaxed max-w-2xl text-lg">
          Every project starts with one question: what is the smallest thing I can build to validate this? Then I ship, learn, and harden the parts that matter.
        </p>
      </div>
    </section>

    <!-- Selected work: flagship feature + asymmetric grid, numbered -->
    <section id="projects" class="px-5 md:px-12 lg:px-20 pb-20 md:pb-28 max-w-6xl mx-auto w-full" aria-labelledby="projects-heading">
      <div data-reveal class="max-w-3xl">
        <h2 id="projects-heading" class="font-display text-3xl md:text-5xl font-bold tracking-tight">
          Selected work
        </h2>
        <p class="mt-4 text-muted leading-relaxed">
          Products and workflows built end to end. Each links to the live build or source.
        </p>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-12">
        {projects.map((project, index) => {
          const live = primaryLink(project.data);
          const ordinal = String(index + 1).padStart(2, "0");

          return (
            <article
              data-reveal
              class:list={[
                cardSpans[index % cardSpans.length],
                "group relative flex flex-col overflow-hidden rounded-[var(--radius-card)] border border-hairline p-7 md:p-9 transition-all duration-300 hover:-translate-y-1 hover:border-teal",
                project.data.flagship ? "bg-gradient-to-br from-teal-soft to-canvas md:flex-row md:gap-10" : "bg-surface/50",
              ]}
            >
              <span
                aria-hidden="true"
                class:list={[
                  "card-index pointer-events-none absolute",
                  project.data.flagship
                    ? "top-6 right-7 text-[5rem] md:text-[8rem]"
                    : "top-5 right-6 text-[3.5rem] md:text-[4.5rem]",
                ]}
              >
                {ordinal}
              </span>

              <div class="relative flex flex-col flex-1">
                {project.data.flagship && (
                  <p class="font-mono text-[0.625rem] tracking-[0.2em] text-teal uppercase mb-3">
                    Flagship
                  </p>
                )}

                <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 pr-16">
                  <h3 class:list={[
                    "font-display font-bold tracking-tight group-hover:text-teal transition-colors",
                    project.data.flagship ? "text-3xl md:text-4xl" : "text-2xl md:text-3xl",
                  ]}>
                    {project.data.title}
                  </h3>
                </div>

                <p class="mt-2 font-mono text-[0.6875rem] tracking-widest text-muted uppercase">
                  {project.data.role} / {project.data.year}
                </p>

                <p class:list={[
                  "mt-5 text-ink leading-relaxed flex-1 font-medium",
                  project.data.flagship ? "text-lg max-w-md" : "max-w-2xl",
                ]}>
                  {project.data.summary}
                </p>

                <ul class="mt-6 flex flex-wrap gap-2" aria-label={`${project.data.title} stack`}>
                  {project.data.stack.map((item) => (
                    <li class="rounded-full bg-canvas border border-hairline px-3 py-1 font-mono text-[0.625rem] tracking-widest text-muted uppercase">
                      {item}
                    </li>
                  ))}
                </ul>

                <div class="mt-7 pt-5 border-t border-hairline flex gap-6 font-mono text-xs tracking-widest uppercase">
                  {project.data.flagship && (
                    <a
                      href={`/projects/${project.id}`}
                      class="text-teal hover:text-ink transition-colors"
                      aria-label={`Read ${project.data.title} case study`}
                    >
                      Case study
                    </a>
                  )}
                  <a
                    href={live.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-ink hover:text-teal transition-colors"
                    aria-label={`View ${project.data.title} (${live.label})`}
                  >
                    {live.label} ↗
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <!-- Latest writing -->
    {hasEnoughPosts && (
      <section id="writing" class="px-5 md:px-12 lg:px-20 py-20 md:py-28 max-w-6xl mx-auto w-full border-t border-hairline" aria-labelledby="latest-writing-heading">
        <div data-reveal class="max-w-3xl">
          <h2 id="latest-writing-heading" class="font-display text-3xl md:text-5xl font-bold tracking-tight">
            Recent writing
          </h2>
          <p class="mt-4 text-muted leading-relaxed">
            Notes on engineering, product development, and AI. Full archive on the blog.
          </p>
        </div>

        <div class="mt-10">
          {latestPosts.map((post) => (
            <article data-reveal class="border-t border-hairline last:border-b">
              <a
                href={post.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group grid gap-2 py-7 md:py-8 md:grid-cols-[10rem_minmax(0,1fr)] md:gap-8 md:items-baseline"
              >
                <p class="font-mono text-xs tracking-widest text-muted uppercase">
                  {formatDate(post.pubDate)}
                </p>
                <div>
                  <h3 class="font-display text-2xl md:text-3xl font-semibold tracking-tight group-hover:text-teal transition-colors">
                    {post.title}
                  </h3>
                  <p class="mt-3 text-muted leading-relaxed max-w-2xl">
                    {formatExcerpt(post.description, 150)}
                  </p>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Experience: timeline showing trajectory -->
    <section class="px-5 md:px-12 lg:px-20 py-20 md:py-28 max-w-6xl mx-auto w-full border-t border-hairline" aria-labelledby="experience-heading">
      <div data-reveal class="max-w-3xl">
        <h2 id="experience-heading" class="font-display text-3xl md:text-5xl font-bold tracking-tight">
          Experience
        </h2>
        <p class="mt-4 text-muted leading-relaxed">
          Product engineering, internships, and CS foundations.
        </p>
      </div>

      <ol class="timeline-track mt-12 relative border-l border-hairline pl-6 md:pl-10">
        {experience.map((entry) => (
          <li data-reveal class="relative pb-12 last:pb-0">
            <span class="absolute -left-[calc(1.5rem+5px)] md:-left-[calc(2.5rem+5px)] top-2 h-2.5 w-2.5 rounded-full bg-canvas border-2 border-teal"></span>
            <div class="grid gap-2 md:grid-cols-[9rem_minmax(0,1fr)] md:items-baseline">
              <p class="font-mono text-xs tracking-widest text-muted uppercase">
                {formatExperienceDate(entry.data)}
              </p>
              <div>
                <h3 class="font-display text-xl md:text-2xl font-semibold tracking-tight">
                  {formatExperienceTitle(entry.data)}
                </h3>
                <p class="mt-2 text-muted leading-relaxed">
                  {entry.data.summary}
                </p>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </section>
  </main>

  <!-- Contact band: always-dark closing panel -->
  <footer id="contact" class="bg-dark-band text-on-band" aria-labelledby="contact-heading">
    <div class="px-5 md:px-12 lg:px-20 py-24 md:py-28 max-w-6xl mx-auto w-full grid gap-12 lg:grid-cols-2 lg:gap-20">
      <div data-reveal>
        <h2 id="contact-heading" class="font-display text-3xl md:text-5xl font-bold tracking-tight">
          Let's build something worth shipping.
        </h2>
        <p class="mt-5 text-on-band-muted leading-relaxed max-w-md">
          Email me directly, or drop a note with the form. I read everything.
        </p>

        <a
          href="mailto:realYushi@gmail.com"
          class="mt-7 inline-block font-display font-semibold text-xl hover:text-teal transition-colors"
        >
          realYushi@gmail.com
        </a>

        <nav class="mt-10 font-mono text-xs tracking-[0.18em] uppercase flex gap-6 md:gap-8 text-on-band-muted">
          <a href="https://github.com/realYushi" target="_blank" rel="noopener noreferrer" class="hover:text-on-band transition-colors">
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/yushi-cui/" target="_blank" rel="noopener noreferrer" class="hover:text-on-band transition-colors">
            LinkedIn
          </a>
          <a href="https://blog.yushi91.com" target="_blank" rel="noopener noreferrer" class="hover:text-on-band transition-colors">
            Blog
          </a>
        </nav>
      </div>

      <!-- Web3Forms: static client-side POST, no backend of ours. -->
      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        class="flex flex-col gap-4"
      >
        <input type="hidden" name="access_key" value="3158397c-c2b2-4b0d-86b7-fe441f3f17c1" />
        <input type="hidden" name="subject" value="New message from yushi91.com" />

        <!-- Honeypot: bots fill this; Web3Forms silently drops those submissions. -->
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

        <label class="flex flex-col gap-2">
          <span class="font-mono text-xs tracking-widest uppercase text-on-band-muted">Name</span>
          <input
            type="text"
            name="name"
            required
            class="bg-white/[0.04] border border-white/15 rounded-[var(--radius-control)] px-4 py-3 text-on-band placeholder:text-on-band-muted focus:border-teal focus:outline-none focus:ring-1 focus:ring-teal transition-colors"
          />
        </label>

        <label class="flex flex-col gap-2">
          <span class="font-mono text-xs tracking-widest uppercase text-on-band-muted">Email</span>
          <input
            type="email"
            name="email"
            required
            class="bg-white/[0.04] border border-white/15 rounded-[var(--radius-control)] px-4 py-3 text-on-band placeholder:text-on-band-muted focus:border-teal focus:outline-none focus:ring-1 focus:ring-teal transition-colors"
          />
        </label>

        <label class="flex flex-col gap-2">
          <span class="font-mono text-xs tracking-widest uppercase text-on-band-muted">Message</span>
          <textarea
            name="message"
            rows="4"
            required
            class="bg-white/[0.04] border border-white/15 rounded-[var(--radius-control)] px-4 py-3 text-on-band placeholder:text-on-band-muted focus:border-teal focus:outline-none focus:ring-1 focus:ring-teal transition-colors resize-y"
          ></textarea>
        </label>

        <button
          type="submit"
          class="self-start mt-2 bg-on-band text-dark-band px-6 py-3 font-display font-semibold text-sm tracking-wide rounded-[var(--radius-control)] transition-all duration-200 hover:bg-teal hover:text-canvas active:scale-[0.98]"
        >
          Send message
        </button>
      </form>
    </div>
  </footer>

  <!-- Client-side scripts. No attributes on the tag: Astro bundles and emits
       this as a hashed module. Adding type="module" (or any attribute) would
       make Astro ship it inline, leaving the bare import unresolved. -->
  <script>
    import { initFreshBlogPosts } from "../lib/client/rss-fetch.ts";

    // Initialize fresh blog posts after page load
    initFreshBlogPosts();

    // Magnetic CTA effect - motivated motion: tactile feedback on the primary
    // CTA. Non-touch only, to avoid janky touch behavior.
    (function() {
      const isTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
      if (isTouch) return;

      const magneticButtons = document.querySelectorAll('.magnetic-cta');

      magneticButtons.forEach(button => {
        button.addEventListener('mousemove', function(e) {
          const rect = this.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;

          this.style.transform = 'translate(' + (x * 0.15) + 'px, ' + (y * 0.15) + 'px)';
        });

        button.addEventListener('mouseleave', function() {
          this.style.transform = 'translate(0, 0)';
        });
      });
    })();
  </script>
</Base>
