---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { formatExperienceDate, formatExperienceTitle } from "../lib/experience";
import { primaryLink } from "../lib/project";

const projects = (await getCollection("projects")).sort(
  (left, right) => left.data.ordering - right.data.ordering,
);

const experience = (await getCollection("experience")).sort(
  (left, right) => left.data.ordering - right.data.ordering,
);
---

<Base
  meta={{
    slug: "/",
    title: "Yushi Cui — AI-Native Full Stack Engineer",
    description:
      "AI-Native Full Stack Engineer based in Auckland, NZ. I build AI-native products, end to end.",
  }}
>
  <main class="min-h-screen flex flex-col">
    <!-- Hero -->
    <section class="flex-1 flex flex-col justify-center px-6 py-24 md:px-12 lg:px-24 max-w-5xl mx-auto w-full">
      <!-- Eyebrow -->
      <p class="font-mono text-xs md:text-sm tracking-widest text-muted uppercase mb-6">
        YUSHI CUI&ensp;·&ensp;AI-NATIVE FULL STACK ENGINEER&ensp;·&ensp;AUCKLAND NZ
      </p>

      <!-- Headline -->
      <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold leading-[1.05] tracking-tight max-w-3xl">
        I build AI-native products, end to end.
      </h1>

      <!-- Subline -->
      <p class="mt-6 text-lg md:text-xl text-muted max-w-2xl leading-relaxed">
        I take a vague idea to a working prototype fast, then harden the best one or two into production — agents, RAG pipelines, and the TypeScript/Node products around them.
      </p>

      <!-- CTA -->
      <div class="mt-10 flex flex-wrap gap-4 items-center">
        <a
          href="mailto:realYushi@gmail.com"
          class="inline-block bg-ink text-canvas px-6 py-3 font-display font-semibold text-sm tracking-wide rounded-sm hover:bg-teal transition-colors"
        >
          Get in touch
        </a>
      </div>

      <!-- Social links -->
      <nav class="mt-10 font-mono text-xs md:text-sm tracking-widest text-muted uppercase flex gap-6 md:gap-8">
        <a href="https://github.com/realYushi" target="_blank" rel="noopener noreferrer" class="hover:text-ink transition-colors">
          GitHub
        </a>
        <span class="text-hairline">·</span>
        <a href="https://www.linkedin.com/in/yushi-cui/" target="_blank" rel="noopener noreferrer" class="hover:text-ink transition-colors">
          LinkedIn
        </a>
        <span class="text-hairline">·</span>
        <a href="https://blog.yushi91.com" target="_blank" rel="noopener noreferrer" class="hover:text-ink transition-colors">
          Blog
        </a>
      </nav>
    </section>

    <!-- Selected projects -->
    <section class="px-6 pb-24 md:px-12 lg:px-24 max-w-5xl mx-auto w-full" aria-labelledby="selected-projects-heading">
      <div class="border-t border-hairline">
        <div class="py-6 md:py-8 border-b border-hairline flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="font-mono text-xs tracking-widest text-muted uppercase mb-3">
              Selected projects
            </p>
            <h2 id="selected-projects-heading" class="font-display text-3xl md:text-4xl font-semibold tracking-tight">
              AI-native work in production and prototype.
            </h2>
          </div>
          <p class="text-muted max-w-xl leading-relaxed">
            A curated list of agent-powered products and workflows. Each row links to the live project or source.
          </p>
        </div>

        <div>
          {projects.map((project) => {
            const live = primaryLink(project.data);

            return (
              <article class="py-6 md:py-8 border-b border-hairline grid gap-4 md:grid-cols-[minmax(0,1fr)_auto] md:items-start">
                <div>
                  <div class="flex flex-wrap items-baseline gap-x-4 gap-y-2">
                    <h3 class="font-display text-2xl md:text-3xl font-semibold tracking-tight">
                      {project.data.title}
                    </h3>
                    <p class="font-mono text-xs tracking-widest text-muted uppercase">
                      {project.data.role} · {project.data.year}
                    </p>
                  </div>
                  <p class="mt-3 text-muted leading-relaxed max-w-2xl">
                    {project.data.summary}
                  </p>
                  <ul class="mt-4 flex flex-wrap gap-x-3 gap-y-2" aria-label={`${project.data.title} stack`}>
                    {project.data.stack.map((item) => (
                      <li class="font-mono text-[0.6875rem] tracking-widest text-muted uppercase">
                        {item.toUpperCase()}
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="flex gap-4 font-mono text-xs tracking-widest uppercase md:pt-2 md:flex-col md:items-end">
                  {project.data.flagship && (
                    <a
                      href={`/projects/${project.id}`}
                      class="text-ink hover:text-teal transition-colors"
                      aria-label={`Read ${project.data.title} case study`}
                    >
                      Case study
                    </a>
                  )}
                  <a
                    href={live.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-ink hover:text-teal transition-colors"
                    aria-label={`View ${project.data.title} (${live.label})`}
                  >
                    {live.label} ↗
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section class="px-6 pb-24 md:px-12 lg:px-24 max-w-5xl mx-auto w-full" aria-labelledby="experience-heading">
      <div class="border-t border-hairline">
        <div class="py-6 md:py-8 border-b border-hairline flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="font-mono text-xs tracking-widest text-muted uppercase mb-3">
              Experience
            </p>
            <h2 id="experience-heading" class="font-display text-3xl md:text-4xl font-semibold tracking-tight">
              Product engineering, internships, and CS foundations.
            </h2>
          </div>
        </div>

        <div>
          {experience.map((entry) => (
            <article class="py-5 md:py-6 border-b border-hairline grid gap-2 md:grid-cols-[10rem_minmax(0,1fr)] md:items-baseline">
              <p class="font-mono text-xs tracking-widest text-muted uppercase">
                {formatExperienceDate(entry.data)}
              </p>
              <div>
                <h3 class="font-display text-xl md:text-2xl font-semibold tracking-tight">
                  {formatExperienceTitle(entry.data)}
                </h3>
                <p class="mt-2 text-muted leading-relaxed">
                  {entry.data.summary}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</Base>
