---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { formatExperienceDate, formatExperienceTitle, getCurrentRole } from "../lib/experience";
import { primaryLink } from "../lib/project";
import { getLatestPosts } from "../lib/blog";
import { generatePostHTML } from "../lib/blog/markup";
import { HOME_FAQ } from "../lib/metadata";

const projects = (await getCollection("projects")).sort(
  (left, right) => left.data.ordering - right.data.ordering,
);

const experience = (await getCollection("experience")).sort(
  (left, right) => left.data.ordering - right.data.ordering,
);

// Current role drives the status band beneath the hero.
const current = getCurrentRole(experience.map(e => e.data));

// Asymmetric rhythm: flagship leads full-width, the rest fall into an uneven
// grid. Indexed by position so the grid never collapses to equal thirds.
const cardSpans = ["lg:col-span-12", "lg:col-span-7", "lg:col-span-5", "lg:col-span-12"];

// Fetch latest blog posts at build time
const latestPosts = await getLatestPosts({ count: 3 });
const hasEnoughPosts = latestPosts.length >= 2;
const homeDescription = "Yushi Cui is a full-stack product engineer in Auckland, NZ, working on AI-assisted products, typed content systems, and Astro/TypeScript apps.";
---

<Base
  meta={{
    slug: "/",
    title: "Yushi Cui - Full-Stack Product Engineer in Auckland, NZ",
    description: homeDescription,
  }}
>
  <main>
    <!-- Hero: type-forward, left-aligned over the blueprint column grid. Four
         elements only: eyebrow, headline (≤2 lines), one-line subtext, CTAs. -->
    <section class="relative min-h-[calc(100dvh-4rem)] flex items-center">
      <div class="col-grid w-full max-w-6xl mx-auto px-5 md:px-12 lg:px-20 py-16 md:py-20">
        <div class="grid items-center gap-10 lg:gap-16 lg:grid-cols-[1fr_auto]">
          <!-- Portrait: transparent cutout, floats over the blueprint grid.
               Swaps treatment with the active scheme (clear lens in light, tinted
               in dark); no ground, so it never clashes with the canvas. -->
          <div
            data-rise="3"
            class="hero-portrait order-1 lg:order-2 justify-self-center lg:justify-self-end w-48 sm:w-56 md:w-64 lg:w-72 shrink-0"
            role="img"
            aria-label="Portrait of Yushi Cui"
          ></div>

          <div class="max-w-4xl order-2 lg:order-1">
            <p data-rise class="font-mono text-xs md:text-sm tracking-[0.22em] text-cobalt uppercase">
              Full-Stack Product Engineer
            </p>

            <h1 data-rise="2" class="mt-6 font-display text-[clamp(2.75rem,6vw,5rem)] font-bold leading-[1.02] tracking-[-0.025em] text-balance">
              I build products <span class="text-cobalt">end to end</span>.
            </h1>

            <p data-rise="3" class="mt-7 text-lg md:text-xl text-muted max-w-xl leading-relaxed">
              Full-stack product engineer in Auckland, New Zealand. I work on AI-assisted products, typed content systems, and fast web applications.
            </p>

            <div data-rise="4" class="mt-10 flex flex-col sm:flex-row flex-wrap gap-3">
              <a
                href="mailto:realYushi@gmail.com"
                class="magnetic-cta inline-flex items-center justify-center bg-ink text-canvas px-6 py-3 font-display font-semibold text-sm tracking-wide rounded-[var(--radius-control)] transition-colors duration-200 hover:bg-cobalt active:scale-[0.98] w-full sm:w-auto"
              >
                Get in touch
              </a>
              <a
                href="#projects"
                class="inline-flex items-center justify-center border border-hairline text-ink px-6 py-3 font-display font-semibold text-sm tracking-wide rounded-[var(--radius-control)] transition-all duration-200 hover:border-cobalt hover:text-cobalt active:scale-[0.98] w-full sm:w-auto"
              >
                See work
              </a>
              <a
                href="/yushi-cui-cv.pdf"
                download="Yushi-Cui-CV.pdf"
                class="inline-flex items-center justify-center gap-1.5 border border-hairline text-ink px-6 py-3 font-display font-semibold text-sm tracking-wide rounded-[var(--radius-control)] transition-all duration-200 hover:border-cobalt hover:text-cobalt active:scale-[0.98] w-full sm:w-auto"
              >
                Download CV
                <span aria-hidden="true">↓</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Status band: real, current credential facts + outbound authority -->
    <section class="border-y border-hairline" aria-label="At a glance">
      <div class="max-w-6xl mx-auto px-5 md:px-12 lg:px-20 py-5 grid gap-4 md:grid-cols-[1fr_1fr_auto] md:items-center font-mono text-xs tracking-[0.12em] uppercase">
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-4">
          {current && current.kind === "role" && (
            <p class="flex items-baseline gap-2">
              <span class="text-muted shrink-0">Currently</span>
              <span class="text-ink truncate">{current.org}</span>
            </p>
          )}
          <p class="flex items-baseline gap-2">
            <span class="text-muted shrink-0">Based in</span>
            <span class="text-ink">Auckland, New Zealand</span>
          </p>
        </div>
        <nav class="flex gap-5 md:gap-7 md:justify-end" aria-label="Profiles">
          <a href="https://github.com/realYushi" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-cobalt transition-colors">GitHub</a>
          <a href="https://www.linkedin.com/in/yushi-cui/" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-cobalt transition-colors">LinkedIn</a>
          <a href="https://blog.yushi91.com" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-cobalt transition-colors">Blog</a>
        </nav>
      </div>
    </section>

    <!-- Approach: single editorial statement, no eyebrow -->
    <section class="px-5 md:px-12 lg:px-20 py-20 md:py-28 max-w-6xl mx-auto w-full">
      <div data-reveal class="max-w-4xl">
        <h2 class="font-display text-2xl md:text-4xl font-semibold tracking-tight leading-[1.2] text-balance">
          I ship the small version first. AI tools speed up the <span class="text-cobalt">0 to 1</span>, but judgment decides what survives.
        </h2>
        <p class="mt-6 text-muted leading-relaxed max-w-2xl text-lg">
          Every project starts with one question: what is the smallest thing I can build to test this? Then I ship it, learn from it, and harden the parts that matter.
        </p>
      </div>
    </section>

    <!-- Selected work: flagship feature + asymmetric grid, numbered -->
    <section id="projects" class="px-5 md:px-12 lg:px-20 pb-20 md:pb-28 max-w-6xl mx-auto w-full" aria-labelledby="projects-heading">
      <div data-reveal class="max-w-3xl">
        <h2 id="projects-heading" class="font-display text-3xl md:text-5xl font-bold tracking-tight">
          Selected work
        </h2>
        <p class="mt-4 text-muted leading-relaxed">
          Products, sites, and workflows I have shipped. Each links to the live build or source.
        </p>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-12">
        {projects.map((project, index) => {
          const live = primaryLink(project.data);
          const ordinal = String(index + 1).padStart(2, "0");

          return (
            <article
              data-reveal
              class:list={[
                cardSpans[index % cardSpans.length],
                "group relative flex flex-col overflow-hidden rounded-[var(--radius-card)] border border-hairline p-7 md:p-9 transition-all duration-300 hover:-translate-y-1 hover:border-cobalt",
                project.data.flagship ? "bg-cobalt-soft md:flex-row md:gap-10" : "bg-surface/50",
              ]}
            >
              <span
                aria-hidden="true"
                class:list={[
                  "card-index pointer-events-none absolute",
                  project.data.flagship
                    ? "top-6 right-7 text-[5rem] md:text-[8rem]"
                    : "top-5 right-6 text-[3.5rem] md:text-[4.5rem]",
                ]}
              >
                {ordinal}
              </span>

              <div class="relative flex flex-col flex-1">
                {project.data.flagship && (
                  <p class="font-mono text-[0.625rem] tracking-[0.2em] text-cobalt uppercase mb-3">
                    Flagship
                  </p>
                )}

                <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 pr-16">
                  <h3 class:list={[
                    "font-display font-bold tracking-tight group-hover:text-cobalt transition-colors",
                    project.data.flagship ? "text-3xl md:text-4xl" : "text-2xl md:text-3xl",
                  ]}>
                    {project.data.title}
                  </h3>
                </div>

                <p class="mt-2 font-mono text-[0.6875rem] tracking-widest text-muted uppercase">
                  {project.data.role} / {project.data.year}
                </p>

                <p class:list={[
                  "mt-5 text-ink leading-relaxed flex-1 font-medium",
                  project.data.flagship ? "text-lg max-w-md" : "max-w-2xl",
                ]}>
                  {project.data.summary}
                </p>

                <ul class="mt-6 flex flex-wrap gap-x-2 gap-y-1.5" aria-label={`${project.data.title} stack`}>
                  {project.data.stack.map((item) => (
                    <li class="rounded-[var(--radius-control)] bg-canvas border border-hairline px-2.5 py-1 font-mono text-[0.625rem] tracking-widest text-muted uppercase">
                      {item}
                    </li>
                  ))}
                </ul>

                <div class="mt-7 pt-5 border-t border-hairline flex gap-6 font-mono text-xs tracking-widest uppercase">
                  {project.data.flagship && (
                    <a
                      href={`/projects/${project.id}/`}
                      class="text-cobalt hover:text-ink transition-colors"
                      aria-label={`Read ${project.data.title} case study`}
                    >
                      Case study
                    </a>
                  )}
                  <a
                    href={live.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-ink hover:text-cobalt transition-colors"
                    aria-label={`View ${project.data.title} (${live.label})`}
                  >
                    {live.label} ↗
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <!-- Latest writing -->
    {hasEnoughPosts && (
      <section id="writing" class="px-5 md:px-12 lg:px-20 py-20 md:py-28 max-w-6xl mx-auto w-full border-t border-hairline" aria-labelledby="latest-writing-heading">
        <div data-reveal class="max-w-3xl">
          <h2 id="latest-writing-heading" class="font-display text-3xl md:text-5xl font-bold tracking-tight">
            Recent writing
          </h2>
          <p class="mt-4 text-muted leading-relaxed">
            Notes on engineering, product development, and AI. Full archive on the blog.
          </p>
        </div>

        <div class="mt-10 border-b border-hairline">
          {latestPosts.map((post) => (
            <article data-reveal class="border-t border-hairline" set:html={generatePostHTML(post)} />
          ))}
        </div>

        <div data-reveal class="mt-10">
          <a
            href="https://blog.yushi91.com"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2 font-mono text-xs tracking-[0.18em] uppercase text-cobalt hover:text-ink transition-colors"
          >
            See more on the blog
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>
      </section>
    )}

    <!-- Experience: timeline showing trajectory -->
    <section class="px-5 md:px-12 lg:px-20 py-20 md:py-28 max-w-6xl mx-auto w-full border-t border-hairline" aria-labelledby="experience-heading">
      <div data-reveal class="max-w-3xl">
        <h2 id="experience-heading" class="font-display text-3xl md:text-5xl font-bold tracking-tight">
          Experience
        </h2>
        <p class="mt-4 text-muted leading-relaxed">
          Product engineering, internships, and CS foundations.
        </p>
      </div>

      <ol class="timeline-track mt-12 relative border-l border-hairline pl-5 sm:pl-6 md:pl-10">
        {experience.map((entry) => (
          <li data-reveal class="relative pb-10 sm:pb-12 last:pb-0">
            <span class="absolute -left-[calc(1.25rem+5px)] sm:-left-[calc(1.5rem+5px)] md:-left-[calc(2.5rem+5px)] top-2 h-2.5 w-2.5 rounded-full bg-canvas border-2 border-cobalt"></span>
            <div class="grid gap-2 md:grid-cols-[9rem_minmax(0,1fr)] md:items-baseline">
              <p class="font-mono text-xs tracking-widest text-muted uppercase">
                {formatExperienceDate(entry.data)}
              </p>
              <div>
                <h3 class="font-display text-lg sm:text-xl md:text-2xl font-semibold tracking-tight">
                  {formatExperienceTitle(entry.data)}
                </h3>
                <p class="mt-2 text-muted leading-relaxed">
                  {entry.data.summary}
                </p>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- FAQ: answer-first profile facts for search and answer engines. -->
    <section class="px-5 md:px-12 lg:px-20 py-20 md:py-28 max-w-6xl mx-auto w-full border-t border-hairline" aria-labelledby="faq-heading">
      <div data-reveal class="max-w-3xl">
        <h2 id="faq-heading" class="font-display text-3xl md:text-5xl font-bold tracking-tight">
          Quick answers
        </h2>
        <p class="mt-4 text-muted leading-relaxed">
          Short profile facts for people, recruiters, and crawlers.
        </p>
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-2">
        {HOME_FAQ.map((item) => (
          <article data-reveal class="rounded-[var(--radius-card)] border border-hairline bg-surface/50 p-6">
            <h3 class="font-display text-xl font-semibold tracking-tight">
              {item.question}
            </h3>
            <p class="mt-3 text-muted leading-relaxed">
              {item.answer}
            </p>
          </article>
        ))}
      </div>
    </section>
  </main>

  <!-- Contact band: always-dark closing panel -->
  <footer id="contact" class="bg-dark-band text-on-band" aria-labelledby="contact-heading">
    <div class="col-grid on-band-grid px-5 md:px-12 lg:px-20 py-16 md:py-24 lg:py-28 max-w-6xl mx-auto w-full grid gap-12 lg:grid-cols-2 lg:gap-20">
      <div data-reveal>
        <h2 id="contact-heading" class="font-display text-3xl md:text-5xl font-bold tracking-tight">
          Let's build something worth shipping.
        </h2>
        <p class="mt-5 text-on-band-muted leading-relaxed max-w-md">
          Email me directly, or drop a note with the form. I read everything.
        </p>

        <a
          href="mailto:realYushi@gmail.com"
          class="mt-7 inline-block font-display font-semibold text-xl hover:text-cobalt transition-colors break-all"
        >
          realYushi@gmail.com
        </a>

        <nav class="mt-10 font-mono text-xs tracking-[0.18em] uppercase flex flex-wrap gap-4 md:gap-8 text-on-band-muted">
          <a href="/about/" class="hover:text-on-band transition-colors">
            About
          </a>
          <a href="/contact/" class="hover:text-on-band transition-colors">
            Contact
          </a>
          <a href="https://github.com/realYushi" target="_blank" rel="noopener noreferrer" class="hover:text-on-band transition-colors">
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/yushi-cui/" target="_blank" rel="noopener noreferrer" class="hover:text-on-band transition-colors">
            LinkedIn
          </a>
          <a href="https://blog.yushi91.com" target="_blank" rel="noopener noreferrer" class="hover:text-on-band transition-colors">
            Blog
          </a>
        </nav>

        <nav class="mt-5 font-mono text-[0.625rem] tracking-[0.18em] uppercase flex gap-5 text-on-band-muted" aria-label="Trust pages">
          <a href="/privacy/" class="hover:text-on-band transition-colors">
            Privacy
          </a>
          <a href="/terms/" class="hover:text-on-band transition-colors">
            Terms
          </a>
        </nav>
      </div>

      <!-- Web3Forms: static client-side POST, no backend of ours. -->
      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        class="flex flex-col gap-4"
      >
        <input type="hidden" name="access_key" value="3158397c-c2b2-4b0d-86b7-fe441f3f17c1" />
        <input type="hidden" name="subject" value="New message from yushi91.com" />

        <!-- Honeypot: bots fill this; Web3Forms silently drops those submissions. -->
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

        <label class="flex flex-col gap-2">
          <span class="font-mono text-xs tracking-widest uppercase text-on-band-muted">Name</span>
          <input
            type="text"
            name="name"
            required
            class="bg-white/[0.04] border border-white/15 rounded-[var(--radius-control)] px-4 py-3 text-on-band placeholder:text-on-band-muted focus:border-cobalt focus:outline-none focus:ring-1 focus:ring-cobalt transition-colors"
          />
        </label>

        <label class="flex flex-col gap-2">
          <span class="font-mono text-xs tracking-widest uppercase text-on-band-muted">Email</span>
          <input
            type="email"
            name="email"
            required
            class="bg-white/[0.04] border border-white/15 rounded-[var(--radius-control)] px-4 py-3 text-on-band placeholder:text-on-band-muted focus:border-cobalt focus:outline-none focus:ring-1 focus:ring-cobalt transition-colors"
          />
        </label>

        <label class="flex flex-col gap-2">
          <span class="font-mono text-xs tracking-widest uppercase text-on-band-muted">Message</span>
          <textarea
            name="message"
            rows="4"
            required
            class="bg-white/[0.04] border border-white/15 rounded-[var(--radius-control)] px-4 py-3 text-on-band placeholder:text-on-band-muted focus:border-cobalt focus:outline-none focus:ring-1 focus:ring-cobalt transition-colors resize-y"
          ></textarea>
        </label>

        <button
          type="submit"
          class="self-start mt-2 bg-on-band text-dark-band px-6 py-3 font-display font-semibold text-sm tracking-wide rounded-[var(--radius-control)] transition-all duration-200 hover:bg-cobalt hover:text-canvas active:scale-[0.98]"
        >
          Send message
        </button>
      </form>
    </div>
  </footer>

  <!-- Client-side scripts. No attributes on the tag: Astro bundles and emits
       this as a hashed module. Adding type="module" (or any attribute) would
       make Astro ship it inline, leaving the bare import unresolved. -->
  <script>
    import { initFreshBlogPosts } from "../lib/blog/client";

    // Refresh blog posts only after the hero is loaded. The build-time posts
    // already render in HTML, so this must not compete with LCP.
    initFreshBlogPosts({ timeoutMs: 2500 });

    // Magnetic CTA effect - motivated motion: tactile feedback on the primary
    // CTA. Non-touch only, to avoid janky touch behavior.
    (function() {
      const isTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
      if (isTouch) return;

      const magneticButtons = document.querySelectorAll('.magnetic-cta');

      magneticButtons.forEach((button) => {
        const el = button as HTMLElement;
        el.addEventListener('mousemove', (event) => {
          const e = event as MouseEvent;
          const rect = el.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;

          el.style.transform = 'translate(' + (x * 0.15) + 'px, ' + (y * 0.15) + 'px)';
        });

        el.addEventListener('mouseleave', () => {
          el.style.transform = 'translate(0, 0)';
        });
      });
    })();
  </script>
</Base>
