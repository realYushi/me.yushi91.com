---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { formatExperienceDate, formatExperienceTitle } from "../lib/experience";
import { primaryLink } from "../lib/project";

const projects = (await getCollection("projects")).sort(
  (left, right) => left.data.ordering - right.data.ordering,
);

const experience = (await getCollection("experience")).sort(
  (left, right) => left.data.ordering - right.data.ordering,
);

// Current role drives the hero "at a glance" panel, so the headline fact stays
// in sync with the experience content instead of being retyped here.
const current = experience.find(
  (entry) => entry.data.kind === "role" && entry.data.end === null,
);

// Asymmetric bento rhythm: alternating wide/narrow spans, never three equal
// cards. Indexed by position so the grid stays varied as projects are added.
const cardSpans = ["lg:col-span-7", "lg:col-span-5", "lg:col-span-5", "lg:col-span-7"];
---

<Base
  meta={{
    slug: "/",
    title: "Yushi Cui - Full-Stack Product Engineer",
    description:
      "Full-Stack Product Engineer based in Auckland, NZ. I build products end to end, from idea to shipped.",
  }}
>
  <main>
    <!-- Hero: asymmetric split, aurora backdrop, at-a-glance fact panel -->
    <section class="relative overflow-hidden min-h-[100dvh] flex items-center">
      <div class="hero-aurora"></div>

      <div class="relative z-10 w-full max-w-6xl mx-auto px-6 md:px-12 lg:px-20 py-28 lg:py-24 grid gap-14 lg:grid-cols-12 lg:gap-12 lg:items-center">
        <div class="lg:col-span-7">
          <p data-rise class="font-mono text-xs md:text-sm tracking-[0.22em] text-teal uppercase">
            Full-Stack Product Engineer
          </p>

          <h1 data-rise="2" class="mt-6 font-display text-[clamp(2.25rem,4.6vw,3.5rem)] font-bold leading-[1.05] tracking-tight text-balance">
            I build products <span class="text-teal">end to end</span>, from idea to shipped.
          </h1>

          <p data-rise="3" class="mt-7 text-lg md:text-xl text-muted max-w-2xl leading-relaxed">
            I turn vague ideas into working products fast, then harden the best into production. Full-stack TypeScript, AI where it earns its place.
          </p>

          <div data-rise="4" class="mt-10 flex flex-wrap gap-3">
            <a
              href="mailto:realYushi@gmail.com"
              class="inline-flex items-center bg-ink text-canvas px-6 py-3 font-display font-semibold text-sm tracking-wide rounded-[var(--radius-control)] transition-all duration-200 hover:bg-teal hover:text-canvas active:scale-[0.98]"
            >
              Get in touch
            </a>
            <a
              href="#projects"
              class="inline-flex items-center border border-hairline text-ink px-6 py-3 font-display font-semibold text-sm tracking-wide rounded-[var(--radius-control)] transition-all duration-200 hover:border-teal hover:text-teal active:scale-[0.98]"
            >
              See projects
            </a>
          </div>

          <nav data-rise="5" class="mt-10 font-mono text-xs tracking-[0.18em] text-muted uppercase flex gap-6 md:gap-8">
            <a href="https://github.com/realYushi" target="_blank" rel="noopener noreferrer" class="hover:text-ink transition-colors">
              GitHub
            </a>
            <a href="https://www.linkedin.com/in/yushi-cui/" target="_blank" rel="noopener noreferrer" class="hover:text-ink transition-colors">
              LinkedIn
            </a>
            <a href="https://blog.yushi91.com" target="_blank" rel="noopener noreferrer" class="hover:text-ink transition-colors">
              Blog
            </a>
          </nav>
        </div>

        <!-- At a glance: real recruiter-facing facts, anchors the asymmetric hero -->
        <aside data-rise="4" class="lg:col-span-5">
          <dl class="rounded-[var(--radius-card)] border border-hairline bg-surface/60 backdrop-blur-sm p-7 md:p-8 grid gap-6">
            {current && current.data.kind === "role" && (
              <div class="grid gap-1.5">
                <dt class="font-mono text-[0.625rem] tracking-[0.2em] text-muted uppercase">Currently</dt>
                <dd class="font-display text-lg font-semibold tracking-tight">{current.data.org}</dd>
              </div>
            )}
            <div class="grid gap-1.5">
              <dt class="font-mono text-[0.625rem] tracking-[0.2em] text-muted uppercase">Based in</dt>
              <dd class="font-display text-lg font-semibold tracking-tight">Auckland, New Zealand</dd>
            </div>
            <div class="grid gap-2.5">
              <dt class="font-mono text-[0.625rem] tracking-[0.2em] text-muted uppercase">Focus</dt>
              <dd class="flex flex-wrap gap-2">
                {["Product engineering", "Full-stack TypeScript", "AI / agents"].map((tag) => (
                  <span class="rounded-full border border-hairline bg-teal-soft px-3 py-1 font-mono text-[0.625rem] tracking-widest text-teal uppercase">
                    {tag}
                  </span>
                ))}
              </dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <!-- Selected projects: asymmetric bento, one cell per project -->
    <section id="projects" class="px-6 md:px-12 lg:px-20 py-24 md:py-32 max-w-6xl mx-auto w-full" aria-labelledby="projects-heading">
      <div data-reveal class="max-w-3xl">
        <h2 id="projects-heading" class="font-display text-3xl md:text-5xl font-semibold tracking-tight">
          Selected work, in production and prototype.
        </h2>
        <p class="mt-4 text-muted leading-relaxed">
          Products and workflows I've built end to end — several agent-powered. Each tile links to the live build or its source.
        </p>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-12">
        {projects.map((project, index) => {
          const live = primaryLink(project.data);

          return (
            <article
              data-reveal
              class:list={[
                cardSpans[index % cardSpans.length],
                "group flex flex-col rounded-[var(--radius-card)] border border-hairline p-7 md:p-9 transition-all duration-300 hover:-translate-y-1 hover:border-teal",
                project.data.flagship ? "bg-gradient-to-br from-teal-soft to-transparent" : "bg-surface/50",
              ]}
            >
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-2">
                <h3 class="font-display text-2xl md:text-3xl font-semibold tracking-tight group-hover:text-teal transition-colors">
                  {project.data.title}
                </h3>
                <p class="font-mono text-[0.6875rem] tracking-widest text-muted uppercase">
                  {project.data.role} · {project.data.year}
                </p>
              </div>

              <p class="mt-4 text-muted leading-relaxed max-w-2xl flex-1">
                {project.data.summary}
              </p>

              <ul class="mt-6 flex flex-wrap gap-2" aria-label={`${project.data.title} stack`}>
                {project.data.stack.map((item) => (
                  <li class="rounded-full border border-hairline px-2.5 py-1 font-mono text-[0.625rem] tracking-widest text-muted uppercase">
                    {item}
                  </li>
                ))}
              </ul>

              <div class="mt-7 pt-5 border-t border-hairline flex gap-6 font-mono text-xs tracking-widest uppercase">
                {project.data.flagship && (
                  <a
                    href={`/projects/${project.id}`}
                    class="text-teal hover:text-ink transition-colors"
                    aria-label={`Read ${project.data.title} case study`}
                  >
                    Case study
                  </a>
                )}
                <a
                  href={live.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-ink hover:text-teal transition-colors"
                  aria-label={`View ${project.data.title} (${live.label})`}
                >
                  {live.label} ↗
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <!-- Experience: vertical timeline ledger (distinct layout family) -->
    <section class="px-6 md:px-12 lg:px-20 pb-24 md:pb-32 max-w-6xl mx-auto w-full" aria-labelledby="experience-heading">
      <div data-reveal class="max-w-3xl">
        <h2 id="experience-heading" class="font-display text-3xl md:text-5xl font-semibold tracking-tight">
          Product engineering, internships, and CS foundations.
        </h2>
      </div>

      <ol class="timeline-track mt-12 relative border-l border-hairline pl-6 md:pl-10">
        {experience.map((entry) => (
          <li data-reveal class="relative pb-10 last:pb-0">
            <span class="absolute -left-[calc(1.5rem+5px)] md:-left-[calc(2.5rem+5px)] top-2 h-2.5 w-2.5 rounded-full bg-canvas border-2 border-teal"></span>
            <div class="grid gap-2 md:grid-cols-[9rem_minmax(0,1fr)] md:items-baseline">
              <p class="font-mono text-xs tracking-widest text-muted uppercase">
                {formatExperienceDate(entry.data)}
              </p>
              <div>
                <h3 class="font-display text-xl md:text-2xl font-semibold tracking-tight">
                  {formatExperienceTitle(entry.data)}
                </h3>
                <p class="mt-2 text-muted leading-relaxed">
                  {entry.data.summary}
                </p>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </section>
  </main>

  <!-- Contact band: always-dark closing panel (bg-dark-band locked by tests) -->
  <footer class="bg-dark-band text-on-band" aria-labelledby="contact-heading">
    <div class="px-6 md:px-12 lg:px-20 py-24 md:py-28 max-w-6xl mx-auto w-full grid gap-12 lg:grid-cols-2 lg:gap-20">
      <div data-reveal>
        <p class="font-mono text-xs tracking-[0.2em] uppercase text-teal mb-4">
          Contact
        </p>
        <h2 id="contact-heading" class="font-display text-3xl md:text-5xl font-semibold tracking-tight">
          Let's build something worth shipping.
        </h2>
        <p class="mt-5 text-on-band-muted leading-relaxed max-w-md">
          Email me directly, or drop a note with the form. I read everything.
        </p>

        <a
          href="mailto:realYushi@gmail.com"
          class="mt-7 inline-block font-display font-semibold text-xl hover:text-teal transition-colors"
        >
          realYushi@gmail.com
        </a>

        <nav class="mt-10 font-mono text-xs tracking-[0.18em] uppercase flex gap-6 md:gap-8 text-on-band-muted">
          <a href="https://github.com/realYushi" target="_blank" rel="noopener noreferrer" class="hover:text-on-band transition-colors">
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/yushi-cui/" target="_blank" rel="noopener noreferrer" class="hover:text-on-band transition-colors">
            LinkedIn
          </a>
          <a href="https://blog.yushi91.com" target="_blank" rel="noopener noreferrer" class="hover:text-on-band transition-colors">
            Blog
          </a>
        </nav>
      </div>

      <!-- Web3Forms: static client-side POST, no backend of ours. -->
      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        class="flex flex-col gap-4"
      >
        <input type="hidden" name="access_key" value="3158397c-c2b2-4b0d-86b7-fe441f3f17c1" />
        <input type="hidden" name="subject" value="New message from yushi91.com" />

        <!-- Honeypot: bots fill this; Web3Forms silently drops those submissions. -->
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

        <label class="flex flex-col gap-2">
          <span class="font-mono text-xs tracking-widest uppercase text-on-band-muted">Name</span>
          <input
            type="text"
            name="name"
            required
            class="bg-white/[0.04] border border-white/15 rounded-[var(--radius-control)] px-4 py-3 text-on-band placeholder:text-on-band-muted focus:border-teal focus:outline-none focus:ring-1 focus:ring-teal transition-colors"
          />
        </label>

        <label class="flex flex-col gap-2">
          <span class="font-mono text-xs tracking-widest uppercase text-on-band-muted">Email</span>
          <input
            type="email"
            name="email"
            required
            class="bg-white/[0.04] border border-white/15 rounded-[var(--radius-control)] px-4 py-3 text-on-band placeholder:text-on-band-muted focus:border-teal focus:outline-none focus:ring-1 focus:ring-teal transition-colors"
          />
        </label>

        <label class="flex flex-col gap-2">
          <span class="font-mono text-xs tracking-widest uppercase text-on-band-muted">Message</span>
          <textarea
            name="message"
            rows="4"
            required
            class="bg-white/[0.04] border border-white/15 rounded-[var(--radius-control)] px-4 py-3 text-on-band placeholder:text-on-band-muted focus:border-teal focus:outline-none focus:ring-1 focus:ring-teal transition-colors resize-y"
          ></textarea>
        </label>

        <button
          type="submit"
          class="self-start mt-2 bg-on-band text-dark-band px-6 py-3 font-display font-semibold text-sm tracking-wide rounded-[var(--radius-control)] transition-all duration-200 hover:bg-teal hover:text-canvas active:scale-[0.98]"
        >
          Send message
        </button>
      </form>
    </div>
  </footer>
</Base>
