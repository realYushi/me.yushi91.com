---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { formatExperienceDate, formatExperienceTitle, getCurrentRole } from "../lib/experience";
import { primaryLink } from "../lib/project";
import { getLatestPosts, type BlogPost } from "../lib/rss-client";
import { formatExcerpt, formatDate } from "../lib/utils";

const projects = (await getCollection("projects")).sort(
  (left, right) => left.data.ordering - right.data.ordering,
);

const experience = (await getCollection("experience")).sort(
  (left, right) => left.data.ordering - right.data.ordering,
);

// Current role drives the hero "at a glance" panel
const current = getCurrentRole(experience.map(e => e.data));

// Asymmetric bento rhythm: alternating wide/narrow spans, never three equal
// cards. Indexed by position so the grid stays varied as projects are added.
const cardSpans = ["lg:col-span-7", "lg:col-span-5", "lg:col-span-5", "lg:col-span-7"];

// Fetch latest blog posts at build time
const latestPosts = await getLatestPosts(3);
const hasEnoughPosts = latestPosts.length >= 2;
---

<Base
  meta={{
    slug: "/",
    title: "Yushi Cui - Full-Stack Product Engineer",
    description:
      "Full-Stack Product Engineer based in Auckland, NZ. I build products end to end, from idea to shipped.",
  }}
>
  <main>
    <!-- Hero: asymmetric split, layered depth, confident display type -->
    <section class="relative overflow-hidden min-h-[100dvh] flex items-center">
      <div class="hero-aurora"></div>

      <!-- Decorative grid overlay - adds technical depth without noise -->
      <div class="absolute inset-0 z-0 opacity-[0.03]" style="background-image: linear-gradient(var(--hairline) 1px, transparent 1px), linear-gradient(90deg, var(--hairline) 1px, transparent 1px); background-size: 48px 48px;"></div>

      <div class="relative z-10 w-full max-w-6xl mx-auto px-5 md:px-12 lg:px-20 py-16 md:py-20 lg:py-16 grid gap-12 md:gap-16 lg:grid-cols-12 lg:gap-16 lg:items-center">
        <div class="lg:col-span-7">
          <p data-rise class="font-mono text-xs md:text-sm tracking-[0.22em] text-teal uppercase">
            Full-Stack Product Engineer
          </p>

          <h1 data-rise="2" class="mt-5 font-display text-[clamp(2.75rem,5.5vw,4.5rem)] font-bold leading-[1.02] tracking-tight text-balance">
            I build products <span class="text-teal">end to end</span>, from idea to shipped.
          </h1>

          <p data-rise="3" class="mt-6 text-lg md:text-xl text-muted max-w-xl leading-relaxed">
            I turn vague ideas into working products fast, then harden the best into production. Full-stack TypeScript, AI where it earns its place.
          </p>

          <div data-rise="4" class="mt-9 flex flex-wrap gap-3">
            <a
              href="mailto:realYushi@gmail.com"
              class="magnetic-cta inline-flex items-center bg-ink text-canvas px-6 py-3 font-display font-semibold text-sm tracking-wide rounded-[var(--radius-control)] transition-all duration-200 hover:bg-teal hover:text-canvas active:scale-[0.98]"
            >
              Get in touch
            </a>
            <a
              href="#projects"
              class="inline-flex items-center border border-hairline text-ink px-6 py-3 font-display font-semibold text-sm tracking-wide rounded-[var(--radius-control)] transition-all duration-200 hover:border-teal hover:text-teal active:scale-[0.98]"
            >
              See projects
            </a>
          </div>

          <nav data-rise="5" class="mt-12 font-mono text-xs tracking-[0.18em] text-muted uppercase flex gap-6 md:gap-8">
            <a href="https://github.com/realYushi" target="_blank" rel="noopener noreferrer" class="hover:text-ink transition-colors">
              GitHub
            </a>
            <a href="https://www.linkedin.com/in/yushi-cui/" target="_blank" rel="noopener noreferrer" class="hover:text-ink transition-colors">
              LinkedIn
            </a>
            <a href="https://blog.yushi91.com" target="_blank" rel="noopener noreferrer" class="hover:text-ink transition-colors">
              Blog
            </a>
          </nav>
        </div>

        <!-- At a glance: tighter, more confident fact display -->
        <aside data-rise="4" class="lg:col-span-5 hero-visual">
          <div class="space-y-6">
            {current && current.kind === "role" && (
              <div class="pl-4 border-l-2 border-teal">
                <p class="font-mono text-[0.625rem] tracking-[0.2em] text-muted uppercase mb-1">Currently</p>
                <p class="font-display text-2xl font-semibold tracking-tight">{current.org}</p>
              </div>
            )}
            <div class="pl-4 border-l border-hairline">
              <p class="font-mono text-[0.625rem] tracking-[0.2em] text-muted uppercase mb-1">Based in</p>
              <p class="font-display text-xl font-semibold tracking-tight">Auckland, New Zealand</p>
            </div>
            <div class="flex flex-wrap gap-2 pt-2">
              {["Product engineering", "Full-stack TypeScript", "AI / agents"].map((tag) => (
                <span class="rounded-md bg-teal-soft border border-teal/20 px-3 py-1.5 font-mono text-[0.625rem] tracking-widest text-teal uppercase">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </section>

    <!-- Latest writing -->
    {hasEnoughPosts && (
      <section class="px-6 md:px-12 lg:px-20 py-24 md:py-32 max-w-6xl mx-auto w-full" aria-labelledby="latest-writing-heading">
        <div data-reveal class="max-w-3xl">
          <h2 id="latest-writing-heading" class="font-display text-3xl md:text-5xl font-semibold tracking-tight">
            Recent writing
          </h2>
          <p class="mt-4 text-muted leading-relaxed">
            Thoughts on engineering, product development, and AI.
          </p>
        </div>

        <div class="mt-12">
          {latestPosts.map((post) => (
            <article data-reveal class="py-6 md:py-8 border-t border-hairline grid gap-4 md:grid-cols-[minmax(0,1fr)_auto] md:items-start">
              <div>
                <a
                  href={post.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block"
                >
                  <h3 class="font-display text-2xl md:text-3xl font-semibold tracking-tight group-hover:text-teal transition-colors">
                    {post.title}
                  </h3>
                </a>
                <p class="mt-2 font-mono text-xs tracking-widest text-muted uppercase">
                  {formatDate(post.pubDate)}
                </p>
                <p class="mt-3 text-muted leading-relaxed max-w-2xl">
                  {formatExcerpt(post.description, 150)}
                </p>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Philosophy: how I work -->
    <section class="px-6 md:px-12 lg:px-20 py-16 md:py-20 max-w-6xl mx-auto w-full">
      <div data-reveal class="max-w-3xl">
        <p class="font-mono text-xs tracking-[0.22em] text-teal uppercase mb-3">
          Approach
        </p>
        <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-tight text-balance">
          I ship fast, then iterate. AI tools speed up the 0 to 1, but judgment determines what survives.
        </h2>
        <p class="mt-4 text-muted leading-relaxed">
          Every project starts with a question: what is the smallest thing I can build to validate this? Then I ship, learn, and harden the parts that matter.
        </p>
      </div>
    </section>

    <!-- Selected projects: asymmetric bento, product thinking foreground -->
    <section id="projects" class="px-6 md:px-12 lg:px-20 py-24 md:py-32 max-w-6xl mx-auto w-full" aria-labelledby="projects-heading">
      <div data-reveal class="max-w-3xl">
        <h2 id="projects-heading" class="font-display text-3xl md:text-5xl font-semibold tracking-tight">
          Selected work
        </h2>
        <p class="mt-4 text-muted leading-relaxed">
          Products and workflows I have built end to end. Each project links to the live build or source.
        </p>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-12">
        {projects.map((project, index) => {
          const live = primaryLink(project.data);

          return (
            <article
              data-reveal
              class:list={[
                cardSpans[index % cardSpans.length],
                "group flex flex-col rounded-[var(--radius-card)] border border-hairline p-7 md:p-9 transition-all duration-300 hover:-translate-y-1 hover:border-teal",
                project.data.flagship ? "bg-gradient-to-br from-teal-soft/80 to-surface/40" : "bg-surface/40",
              ]}
            >
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-2">
                <h3 class="font-display text-2xl md:text-3xl font-semibold tracking-tight group-hover:text-teal transition-colors">
                  {project.data.title}
                </h3>
                <p class="font-mono text-[0.6875rem] tracking-widest text-muted uppercase">
                  {project.data.role} · {project.data.year}
                </p>
              </div>

              <p class="mt-4 text-ink leading-relaxed max-w-2xl flex-1 font-medium">
                {project.data.summary}
              </p>

              <ul class="mt-6 flex flex-wrap gap-2" aria-label={`${project.data.title} stack`}>
                {project.data.stack.map((item) => (
                  <li class="rounded-md bg-canvas border border-hairline px-2.5 py-1 font-mono text-[0.625rem] tracking-widest text-muted uppercase">
                    {item}
                  </li>
                ))}
              </ul>

              <div class="mt-7 pt-5 border-t border-hairline flex gap-6 font-mono text-xs tracking-widest uppercase">
                {project.data.flagship && (
                  <a
                    href={`/projects/${project.id}`}
                    class="text-teal hover:text-ink transition-colors"
                    aria-label={`Read ${project.data.title} case study`}
                  >
                    Case study
                  </a>
                )}
                <a
                  href={live.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-ink hover:text-teal transition-colors"
                  aria-label={`View ${project.data.title} (${live.label})`}
                >
                  {live.label} ↗
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <!-- Experience: timeline showing trajectory and growth -->
    <section class="px-6 md:px-12 lg:px-20 pb-24 md:pb-32 max-w-6xl mx-auto w-full" aria-labelledby="experience-heading">
      <div data-reveal class="max-w-3xl">
        <h2 id="experience-heading" class="font-display text-3xl md:text-5xl font-semibold tracking-tight">
          Experience
        </h2>
        <p class="mt-4 text-muted leading-relaxed">
          Product engineering, internships, and CS foundations.
        </p>
      </div>

      <ol class="timeline-track mt-12 relative border-l border-hairline pl-6 md:pl-10">
        {experience.map((entry) => (
          <li data-reveal class="relative pb-12 last:pb-0">
            <span class="absolute -left-[calc(1.5rem+5px)] md:-left-[calc(2.5rem+5px)] top-2 h-2.5 w-2.5 rounded-full bg-canvas border-2 border-teal"></span>
            <div class="grid gap-2 md:grid-cols-[9rem_minmax(0,1fr)] md:items-baseline">
              <p class="font-mono text-xs tracking-widest text-muted uppercase">
                {formatExperienceDate(entry.data)}
              </p>
              <div>
                <h3 class="font-display text-xl md:text-2xl font-semibold tracking-tight">
                  {formatExperienceTitle(entry.data)}
                </h3>
                <p class="mt-2 text-muted leading-relaxed">
                  {entry.data.summary}
                </p>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </section>
  </main>

  <!-- Contact band: always-dark closing panel -->
  <footer class="bg-dark-band text-on-band" aria-labelledby="contact-heading">
    <div class="px-6 md:px-12 lg:px-20 py-24 md:py-28 max-w-6xl mx-auto w-full grid gap-12 lg:grid-cols-2 lg:gap-20">
      <div data-reveal>
        <h2 id="contact-heading" class="font-display text-3xl md:text-5xl font-semibold tracking-tight">
          Let's build something worth shipping.
        </h2>
        <p class="mt-5 text-on-band-muted leading-relaxed max-w-md">
          Email me directly, or drop a note with the form. I read everything.
        </p>

        <a
          href="mailto:realYushi@gmail.com"
          class="mt-7 inline-block font-display font-semibold text-xl hover:text-teal transition-colors"
        >
          realYushi@gmail.com
        </a>

        <nav class="mt-10 font-mono text-xs tracking-[0.18em] uppercase flex gap-6 md:gap-8 text-on-band-muted">
          <a href="https://github.com/realYushi" target="_blank" rel="noopener noreferrer" class="hover:text-on-band transition-colors">
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/yushi-cui/" target="_blank" rel="noopener noreferrer" class="hover:text-on-band transition-colors">
            LinkedIn
          </a>
          <a href="https://blog.yushi91.com" target="_blank" rel="noopener noreferrer" class="hover:text-on-band transition-colors">
            Blog
          </a>
        </nav>
      </div>

      <!-- Web3Forms: static client-side POST, no backend of ours. -->
      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        class="flex flex-col gap-4"
      >
        <input type="hidden" name="access_key" value="3158397c-c2b2-4b0d-86b7-fe441f3f17c1" />
        <input type="hidden" name="subject" value="New message from yushi91.com" />

        <!-- Honeypot: bots fill this; Web3Forms silently drops those submissions. -->
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

        <label class="flex flex-col gap-2">
          <span class="font-mono text-xs tracking-widest uppercase text-on-band-muted">Name</span>
          <input
            type="text"
            name="name"
            required
            class="bg-white/[0.04] border border-white/15 rounded-[var(--radius-control)] px-4 py-3 text-on-band placeholder:text-on-band-muted focus:border-teal focus:outline-none focus:ring-1 focus:ring-teal transition-colors"
          />
        </label>

        <label class="flex flex-col gap-2">
          <span class="font-mono text-xs tracking-widest uppercase text-on-band-muted">Email</span>
          <input
            type="email"
            name="email"
            required
            class="bg-white/[0.04] border border-white/15 rounded-[var(--radius-control)] px-4 py-3 text-on-band placeholder:text-on-band-muted focus:border-teal focus:outline-none focus:ring-1 focus:ring-teal transition-colors"
          />
        </label>

        <label class="flex flex-col gap-2">
          <span class="font-mono text-xs tracking-widest uppercase text-on-band-muted">Message</span>
          <textarea
            name="message"
            rows="4"
            required
            class="bg-white/[0.04] border border-white/15 rounded-[var(--radius-control)] px-4 py-3 text-on-band placeholder:text-on-band-muted focus:border-teal focus:outline-none focus:ring-1 focus:ring-teal transition-colors resize-y"
          ></textarea>
        </label>

        <button
          type="submit"
          class="self-start mt-2 bg-on-band text-dark-band px-6 py-3 font-display font-semibold text-sm tracking-wide rounded-[var(--radius-control)] transition-all duration-200 hover:bg-teal hover:text-canvas active:scale-[0.98]"
        >
          Send message
        </button>
      </form>
    </div>
  </footer>

  <!-- Client-side scripts -->
  <script type="module">
    import { initFreshBlogPosts } from "./lib/client/rss-fetch.ts";

    // Initialize fresh blog posts after page load
    initFreshBlogPosts();

    // Magnetic CTA effect - motivated motion: adds tactile feedback to primary CTA
    // Only applies on non-touch devices to avoid janky touch behavior
    (function() {
      const isTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
      if (isTouch) return;

      const magneticButtons = document.querySelectorAll('.magnetic-cta');

      magneticButtons.forEach(button => {
        button.addEventListener('mousemove', function(e) {
          const rect = this.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;

          this.style.transform = 'translate(' + (x * 0.15) + 'px, ' + (y * 0.15) + 'px)';
        });

        button.addEventListener('mouseleave', function() {
          this.style.transform = 'translate(0, 0)';
        });
      });
    })();
  </script>
</Base>
