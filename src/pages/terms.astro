---
import Base from "../layouts/Base.astro";

const description = "Basic terms for using yushi91.com, Yushi Cui's personal portfolio.";
---

<Base
  meta={{
    slug: "/terms/",
    title: "Terms - Yushi Cui",
    description,
  }}
>
  <main class="px-5 md:px-12 lg:px-20 py-16 md:py-24 max-w-5xl mx-auto w-full">
    <a href="/" class="font-mono text-xs tracking-widest uppercase text-muted hover:text-cobalt transition-colors">
      ← Home
    </a>

    <h1 class="mt-10 font-display text-[clamp(2.75rem,7vw,5rem)] font-bold leading-[1.02] tracking-[-0.025em]">
      Terms
    </h1>

    <div class="mt-8 space-y-8 text-muted leading-relaxed max-w-3xl">
      <section>
        <h2 class="font-display text-2xl font-semibold tracking-tight text-ink">Site purpose</h2>
        <p class="mt-3">
          This site is Yushi Cui's personal portfolio. It shares profile information, selected work, writing links, and contact details.
        </p>
      </section>

      <section>
        <h2 class="font-display text-2xl font-semibold tracking-tight text-ink">Content</h2>
        <p class="mt-3">
          Portfolio copy, project descriptions, and design assets are for general information. External project links may change outside this site.
        </p>
      </section>

      <section>
        <h2 class="font-display text-2xl font-semibold tracking-tight text-ink">Contact</h2>
        <p class="mt-3">
          For questions about this site, email <a href="mailto:realYushi@gmail.com" class="text-cobalt hover:text-ink transition-colors">realYushi@gmail.com</a>.
        </p>
      </section>
    </div>
  </main>
</Base>
