---
import Base from "../layouts/Base.astro";

const description = "About Yushi Cui, a full-stack product engineer in Auckland, New Zealand working on AI-assisted products and Astro/TypeScript applications.";
---

<Base
  meta={{
    slug: "/about/",
    title: "About Yushi Cui - Full-Stack Product Engineer",
    description,
  }}
>
  <main class="px-5 md:px-12 lg:px-20 py-16 md:py-24 max-w-5xl mx-auto w-full">
    <a href="/" class="font-mono text-xs tracking-widest uppercase text-muted hover:text-cobalt transition-colors">
      ← Home
    </a>

    <h1 class="mt-10 font-display text-[clamp(2.75rem,7vw,5rem)] font-bold leading-[1.02] tracking-[-0.025em]">
      About Yushi Cui
    </h1>

    <p class="mt-6 text-xl md:text-2xl text-muted leading-relaxed max-w-3xl font-medium">
      I'm a full-stack product engineer in Auckland, New Zealand. I work on AI-assisted products, typed content systems, and fast web applications.
    </p>

    <section class="mt-12 grid gap-8 md:grid-cols-2">
      <article class="rounded-[var(--radius-card)] border border-hairline bg-surface/50 p-6">
        <h2 class="font-display text-2xl font-semibold tracking-tight">What I build</h2>
        <p class="mt-3 text-muted leading-relaxed">
          I build product surfaces with Astro, TypeScript, React, Node.js, structured content, and AI workflows. I care about crawlable HTML, clear data shapes, and getting useful versions shipped early.
        </p>
      </article>

      <article class="rounded-[var(--radius-card)] border border-hairline bg-surface/50 p-6">
        <h2 class="font-display text-2xl font-semibold tracking-tight">How I work</h2>
        <p class="mt-3 text-muted leading-relaxed">
          I start with the smallest useful version, ship it, learn from the result, and harden the parts that matter. AI tools help with the first draft. Engineering judgment decides what stays.
        </p>
      </article>
    </section>
  </main>
</Base>
