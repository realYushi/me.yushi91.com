---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import { primaryLink } from "../../lib/project";

export async function getStaticPaths() {
  const flagships = (await getCollection("projects")).filter(
    (entry) => entry.data.flagship,
  );

  return flagships.map((project) => {
    if (!project.body || project.body.trim().length === 0) {
      throw new Error(
        `Flagship project "${project.id}" has no case-study body.`,
      );
    }

    return { params: { slug: project.id }, props: { project } };
  });
}

const { project } = Astro.props;
const { Content } = await render(project);
const live = primaryLink(project.data);
const stack = project.data.stack.join(" / ");
---

<Base
  meta={{
    slug: `/projects/${project.id}`,
    title: `${project.data.title} - Yushi Cui`,
    description: project.data.summary,
  }}
>
  <main>
    <!-- Header: editorial title block -->
    <header>
      <div class="max-w-5xl mx-auto w-full px-5 md:px-12 lg:px-20 pt-10 pb-10 md:pt-14 md:pb-12">
        <a href="/#projects" class="font-mono text-xs tracking-widest uppercase text-muted hover:text-cobalt transition-colors">
          ← Selected work
        </a>

        <p data-rise class="mt-10 font-mono text-xs tracking-[0.2em] text-cobalt uppercase">
          Case study
        </p>
        <h1 data-rise="2" class="mt-4 font-display text-[clamp(2.5rem,7vw,4.75rem)] font-bold leading-[1.02] tracking-[-0.025em]">
          {project.data.title}
        </h1>
        <p data-rise="3" class="mt-5 text-xl md:text-2xl text-muted leading-relaxed max-w-3xl font-medium">
          {project.data.summary}
        </p>

        <dl data-rise="4" class="mt-8 grid gap-x-6 gap-y-3 border-t border-hairline pt-5 font-mono text-xs tracking-widest uppercase text-muted sm:grid-cols-2 lg:grid-cols-4">
          <div class="flex flex-col gap-1.5">
            <dt class="text-ink">Role</dt>
            <dd>{project.data.role}</dd>
          </div>
          <div class="flex flex-col gap-1.5">
            <dt class="text-ink">Stack</dt>
            <dd>{stack}</dd>
          </div>
          <div class="flex flex-col gap-1.5">
            <dt class="text-ink">Year</dt>
            <dd>{project.data.year}</dd>
          </div>
          <div class="flex flex-col gap-1.5">
            <dt class="text-ink">Link</dt>
            <dd>
              <a href={live.url} target="_blank" rel="noopener noreferrer" class="text-cobalt hover:text-ink transition-colors">
                {live.label.toUpperCase()} ↗
              </a>
            </dd>
          </div>
        </dl>
      </div>
    </header>

    <article class="max-w-5xl mx-auto w-full px-5 md:px-12 lg:px-20 pb-20">
      <div class="case-study" data-reveal>
        <Content />
      </div>

      <div class="mt-16 border-t border-hairline pt-10">
        <a
          href="/#projects"
          class="inline-flex items-center font-display font-semibold text-sm tracking-wide text-ink hover:text-cobalt transition-colors"
        >
          ← Back to selected projects
        </a>
      </div>
    </article>
  </main>
</Base>
