---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import { primaryLink } from "../../lib/project";

export async function getStaticPaths() {
  const flagships = (await getCollection("projects")).filter(
    (entry) => entry.data.flagship,
  );

  return flagships.map((project) => {
    if (!project.body || project.body.trim().length === 0) {
      throw new Error(
        `Flagship project "${project.id}" has no case-study body.`,
      );
    }

    return { params: { slug: project.id }, props: { project } };
  });
}

const { project } = Astro.props;
const { Content } = await render(project);
const live = primaryLink(project.data);
const stack = project.data.stack.join(" / ");
---

<Base
  meta={{
    slug: `/projects/${project.id}`,
    title: `${project.data.title} — Yushi Cui`,
    description: project.data.summary,
  }}
>
  <main class="min-h-screen px-6 py-16 md:px-12 lg:px-24 max-w-5xl mx-auto w-full">
    <a href="/" class="font-mono text-xs tracking-widest uppercase text-muted hover:text-ink transition-colors">
      ← Home
    </a>

    <article class="mt-12">
      <header class="border-t border-hairline pt-8 pb-10">
        <p class="font-mono text-xs tracking-widest text-muted uppercase mb-4">
          Flagship case study
        </p>
        <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold leading-[1.05] tracking-tight">
          {project.data.title}
        </h1>
        <p class="mt-6 text-xl md:text-2xl text-muted leading-relaxed max-w-3xl">
          {project.data.summary}
        </p>

        <div class="mt-8 grid gap-4 border-y border-hairline py-5 font-mono text-xs tracking-widest uppercase text-muted md:grid-cols-4">
          <p><span class="text-ink">ROLE</span> · {project.data.role}</p>
          <p><span class="text-ink">STACK</span> · {stack}</p>
          <p><span class="text-ink">YEAR</span> · {project.data.year}</p>
          <p>
            <a href={live.url} target="_blank" rel="noopener noreferrer" class="text-ink hover:text-teal transition-colors">
              {live.label.toUpperCase()} ↗
            </a>
          </p>
        </div>
      </header>

      <div class="case-study">
        <Content />
      </div>
    </article>
  </main>
</Base>
